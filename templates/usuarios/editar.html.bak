{% extends "base.html" %}

{% block title %}Editar Usuario{% endblock %}

{% block content %}
<h2 class="mb-4">Editar Usuario: {{ usuario.username }}</h2>

<div class="card">
    <div class="card-body">
        <form method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Usuario</label>
                    <input type="text" value="{{ usuario.username }}" class="form-control" disabled>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input type="text" name="nombre" value="{{ usuario.nombre }}" class="form-control" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Nueva Contraseña (dejar vacío para no cambiar)</label>
                    <input type="password" name="password" class="form-control">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Rol</label>
                    <select name="rol" id="rol" class="form-select" required>
                        <option value="admin" {% if usuario.rol == 'admin' %}selected{% endif %}>Administrador</option>
                        <option value="coordinador" {% if usuario.rol == 'coordinador' %}selected{% endif %}>Coordinador</option>
                        <option value="resolutor" {% if usuario.rol == 'resolutor' %}selected{% endif %}>Resolutor</option>
                        <option value="solicitante" {% if usuario.rol == 'solicitante' %}selected{% endif %}>Solicitante</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3" id="departamento-container" style="display: none;">
                    <label class="form-label">Departamento (Solicitantes)</label>
                    <select name="departamento_id" id="departamento_id" class="form-select">
                        <option value="">Seleccionar...</option>
                        {% for dept in departamentos %}
                        <option value="{{ dept.id }}" {% if usuario.departamento_id == dept.id %}selected{% endif %}>{{ dept.nombre }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6 mb-3" id="secciones-container" style="display: none;">
                    <label class="form-label">Secciones (Resolutores) - Múltiples</label>
                    <select name="secciones_ids" id="secciones_ids" class="form-select" multiple size="8">
                        {% for sec in secciones %}
                        <option value="{{ sec.id }}" {% if sec.id in secciones_ids %}selected{% endif %}>{{ sec.nombre }} ({{ sec.medio }})</option>
                        {% endfor %}
                    </select>
                    <small class="text-muted">Mantén Ctrl/Cmd para seleccionar múltiples</small>
                </div>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input type="checkbox" name="activo" class="form-check-input" {% if usuario.activo %}checked{% endif %}>
                    <label class="form-check-label">Usuario Activo</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            <a href="{{ url_for('usuarios.index') }}" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
function updateFields() {
    const rol = $('#rol').val();
    if (rol === 'resolutor') {
        $('#secciones-container').show();
        $('#departamento-container').hide();
    } else if (rol === 'solicitante') {
        $('#departamento-container').show();
        $('#secciones-container').hide();
    } else {
        $('#secciones-container').hide();
        $('#departamento-container').hide();
    }
}
updateFields();
$('#rol').on('change', updateFields);
</script>
{% endblock %}
