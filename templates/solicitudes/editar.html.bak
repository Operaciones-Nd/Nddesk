{% extends "base.html" %}

{% block title %}Editar Ticket #{{ '%04d'|format(ticket.id) }}{% endblock %}

{% block content %}
<div class="row">
    <div class="col-12">
        <div class="d-flex align-items-center mb-4">
            <a href="{{ url_for('solicitudes.ver', id=ticket.id) }}" class="btn btn-outline-secondary btn-sm mr-3">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
            <h4 class="mb-0" style="font-weight: 700; color: #1e293b;">
                Editar Ticket #{{ '%04d'|format(ticket.id) }}
            </h4>
        </div>
    </div>
</div>

<form method="POST" id="editForm">
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <!-- Estado y Prioridad -->
                    <div class="form-section">
                        <div class="form-section-title">
                            <i class="fas fa-sliders-h mr-2"></i>Estado y Prioridad
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label">Estado</label>
                                    <select name="estado" id="estado" class="form-select">
                                        <option value="Pendiente" {% if ticket.estado == 'Pendiente' %}selected{% endif %}>Pendiente</option>
                                        <option value="Planificado" {% if ticket.estado == 'Planificado' %}selected{% endif %}>Planificado</option>
                                        <option value="Solucionado" {% if ticket.estado == 'Solucionado' %}selected{% endif %}>Solucionado</option>
                                        <option value="Cerrado" {% if ticket.estado == 'Cerrado' %}selected{% endif %}>Cerrado</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label">Prioridad</label>
                                    <select name="prioridad" class="form-select">
                                        <option value="Baja" {% if ticket.prioridad == 'Baja' %}selected{% endif %}>Baja</option>
                                        <option value="Media" {% if ticket.prioridad == 'Media' %}selected{% endif %}>Media</option>
                                        <option value="Alta" {% if ticket.prioridad == 'Alta' %}selected{% endif %}>Alta</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Solución -->
                    <div class="form-section">
                        <div class="form-section-title">
                            <i class="fas fa-check-circle mr-2"></i>Solución
                        </div>
                        <div class="form-group">
                            <label class="form-label">Tipo de Solución</label>
                            <select name="solucion" id="solucion" class="form-select">
                                <option value="" {% if not ticket.solucion %}selected{% endif %}>Sin resolver</option>
                                <option value="Publicado" {% if ticket.solucion == 'Publicado' %}selected{% endif %}>Publicado</option>
                                <option value="Publicado - vendido" {% if ticket.solucion == 'Publicado - vendido' %}selected{% endif %}>Publicado - vendido</option>
                                <option value="Publicado - no vendido" {% if ticket.solucion == 'Publicado - no vendido' %}selected{% endif %}>Publicado - no vendido</option>
                                <option value="No publicado" {% if ticket.solucion == 'No publicado' %}selected{% endif %}>No publicado</option>
                            </select>
                        </div>
                        <div id="alertNoPublicado" class="alert alert-warning" style="display: none; border-left: 4px solid #f59e0b;">
                            <i class="fas fa-exclamation-triangle mr-2"></i>
                            <strong>Atención:</strong> Has seleccionado "No publicado". Asegúrate de documentar el motivo en la bitácora.
                        </div>
                    </div>

                    <!-- Bitácoras -->
                    <div class="form-section">
                        <div class="form-section-title">
                            <i class="fas fa-clipboard-list mr-2"></i>Bitácoras
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-eye mr-1"></i>Bitácora Pública
                            </label>
                            <textarea name="bitacora_publica" class="form-control" rows="4" 
                                      placeholder="Información visible para el solicitante...">{{ ticket.bitacora_publica or '' }}</textarea>
                            <small class="form-text text-muted">Esta información será visible para el solicitante</small>
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-eye-slash mr-1"></i>Bitácora Interna
                            </label>
                            <textarea name="bitacora_oculta" class="form-control" rows="4" 
                                      placeholder="Notas internas del equipo...">{{ ticket.bitacora_oculta or '' }}</textarea>
                            <small class="form-text text-muted">Solo visible para el equipo resolutor y administradores</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel Lateral -->
        <div class="col-lg-4">
            <!-- Información del Ticket -->
            <div class="info-card">
                <div style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.75rem; margin-bottom: 1rem;">
                    <h6 style="font-weight: 700; color: #1e293b; margin: 0;">
                        <i class="fas fa-info-circle mr-2"></i>Información
                    </h6>
                </div>
                <div class="info-item">
                    <div class="info-label">Solicitante</div>
                    <div class="info-value">{{ ticket.usuario.nombre }}</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Sección</div>
                    <div class="info-value">{{ ticket.seccion }}</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Fecha Publicación</div>
                    <div class="info-value">{{ ticket.fecha_publicacion.strftime('%d/%m/%Y') }}</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Creado</div>
                    <div class="info-value">{{ ticket.created_at.strftime('%d/%m/%Y %H:%M') }}</div>
                </div>
            </div>

            <!-- Acciones -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save mr-2"></i>Guardar Cambios
                </button>
                <a href="{{ url_for('solicitudes.ver', id=ticket.id) }}" class="btn btn-outline-secondary">
                    <i class="fas fa-times mr-2"></i>Cancelar
                </a>
                {% if ticket.estado != 'Cerrado' %}
                <button type="button" class="btn btn-success" data-toggle="modal" data-target="#modalCerrar">
                    <i class="fas fa-check-circle mr-2"></i>Cerrar Ticket
                </button>
                {% endif %}
            </div>
        </div>
    </div>
</form>

<!-- Modal Cerrar Ticket -->
<div class="modal fade" id="modalCerrar" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                <h5 class="modal-title" style="font-weight: 700; color: #1e293b;">
                    <i class="fas fa-check-circle mr-2" style="color: #10b981;"></i>
                    Cerrar Ticket #{{ '%04d'|format(ticket.id) }}
                </h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <form method="POST" action="{{ url_for('solicitudes.cerrar', id=ticket.id) }}">
                <div class="modal-body">
                    <div class="alert alert-info" style="border-left: 4px solid #3b82f6;">
                        <i class="fas fa-info-circle mr-2"></i>
                        <strong>Importante:</strong> Al cerrar el ticket, no podrá ser modificado posteriormente.
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Solución Final <span class="text-danger">*</span></label>
                        <select name="solucion" id="solucionModal" class="form-select" required>
                            <option value="Publicado - vendido">Publicado - vendido</option>
                            <option value="Publicado - no vendido">Publicado - no vendido</option>
                            <option value="">Seleccionar...</option>
                            <option value="Publicado">Publicado</option>
                            <option value="No publicado">No publicado</option>
                        </select>
                    </div>
                    
                    <div id="alertModalNoPublicado" class="alert alert-warning" style="display: none; border-left: 4px solid #f59e0b;">
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        <strong>Atención:</strong> Documenta el motivo por el cual no se publicó.
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-eye mr-1"></i>Bitácora Pública
                        </label>
                        <textarea name="bitacora_publica" class="form-control" rows="3" 
                                  placeholder="Resumen de la solución para el solicitante..."></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-eye-slash mr-1"></i>Bitácora Interna
                        </label>
                        <textarea name="bitacora_oculta" class="form-control" rows="3" 
                                  placeholder="Notas internas del cierre..."></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #e2e8f0;">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
                        <i class="fas fa-times mr-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check-circle mr-2"></i>Cerrar Ticket
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function() {
    // Alerta cuando se selecciona "No publicado" en el formulario
    $('#solucion').on('change', function() {
        if ($(this).val() === 'No publicado') {
            $('#alertNoPublicado').slideDown();
        } else {
            $('#alertNoPublicado').slideUp();
        }
    });
    
    // Alerta cuando se selecciona "No publicado" en el modal
    $('#solucionModal').on('change', function() {
        if ($(this).val() === 'No publicado') {
            $('#alertModalNoPublicado').slideDown();
        } else {
            $('#alertModalNoPublicado').slideUp();
        }
    });
    
    // Mostrar alerta si ya está seleccionado al cargar
    if ($('#solucion').val() === 'No publicado') {
        $('#alertNoPublicado').show();
    }
});
</script>
{% endblock %}
